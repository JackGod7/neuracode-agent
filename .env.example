# ============================================
# Server
# ============================================
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# WhatsApp Cloud API (Meta for Developers)
# ============================================
# Inventas tú un string aleatorio largo
VERIFY_TOKEN=

# Meta Dev → tu app → WhatsApp → API Setup
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=

# Meta Dev → tu app → Configuración básica → App secret
APP_SECRET=

# Versión Graph API
GRAPH_API_VERSION=v21.0

# ============================================
# LLM
# ============================================
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# platform.openai.com → solo para embeddings de RAG
OPENAI_API_KEY=

# Modelos (opcional, defaults razonables)
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# Supabase (Postgres + pgvector)
# ============================================
# Settings → API en tu proyecto Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ============================================
# Mercado Pago (pagos LATAM)
# ============================================
# mercadopago.com.pe → Developers → Credenciales (production)
MP_ACCESS_TOKEN=

# URL pública del agente (para callbacks de pago)
BASE_URL=https://tu-app.up.railway.app

# ============================================
# Cal.com (agendamiento)
# ============================================
# Tu link público de Cal.com (ej: https://cal.com/jack-aguilar/30min)
CAL_LINK=

# ============================================
# Escalamiento
# ============================================
# Número WhatsApp personal de Jack (sin +, ej: 51999888777)
JACK_WHATSAPP=
