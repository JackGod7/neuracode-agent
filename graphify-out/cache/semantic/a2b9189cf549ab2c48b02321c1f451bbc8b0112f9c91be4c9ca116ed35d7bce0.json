{"nodes": [{"id": "spec001_decisions", "label": "Spec 001 Webhook Meta \u2014 Decisions", "file_type": "document", "source_file": "specs/001-webhook-meta/decisions.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "spec001_hmac_sha256", "label": "HMAC SHA256 Signature Validation", "file_type": "document", "source_file": "specs/001-webhook-meta/decisions.md", "source_location": "line 11-15", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Use crypto.timingSafeEqual() instead of === to prevent timing attacks that could leak the expected signature. try/catch handles different-length buffer throw."}, {"id": "spec001_fire_and_forget", "label": "Fire-and-Forget Async Processing Pattern", "file_type": "document", "source_file": "specs/001-webhook-meta/decisions.md", "source_location": "line 17-24", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "reply.code(200).send('ok') before processing to meet Meta's <5s requirement. BullMQ/Redis deferred to Phase 1 when volume justifies it. Risk: message loss if process dies between 200 and processing."}, {"id": "spec001_raw_body_parser", "label": "Fastify Raw Body Parser (addContentTypeParser)", "file_type": "document", "source_file": "specs/001-webhook-meta/decisions.md", "source_location": "line 3-9", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Use Fastify native addContentTypeParser with parseAs: 'buffer' to retain raw body for HMAC validation. Rejects fastify-raw-body plugin as unnecessary wrapper."}], "edges": [{"source": "spec001_decisions", "target": "spec001_hmac_sha256", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "specs/001-webhook-meta/decisions.md", "source_location": "line 11", "weight": 1.0}, {"source": "spec001_decisions", "target": "spec001_fire_and_forget", "relation": "