{
  "name": "neuracode-agent",
  "version": "0.1.0",
  "description": "WhatsApp agent para Neuracode — bootcamp Harness Engineering",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "ingest": "tsx --env-file=.env scripts/ingest.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.46.0",
    "axios": "^1.7.7",
    "fastify": "^5.1.0",
    "mercadopago": "^2.0.15",
    "openai": "^4.73.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
