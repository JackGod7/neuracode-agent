{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(tsc:*)",
      "Bash(node:*)",
      "Bash(tsx:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Edit(src/**)",
      "Edit(scripts/**)",
      "Edit(specs/**)",
      "Edit(docs/**)",
      "Edit(knowledge/**)",
      "Edit(supabase/**)",
      "Edit(tests/**)",
      "Edit(.github/workflows/**)",
      "Write(src/**)",
      "Write(scripts/**)",
      "Write(specs/**)",
      "Write(docs/**)",
      "Write(tests/**)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.production)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.production)",
      "Edit(/etc/**)",
      "Edit(~/.ssh/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/pre-tool-use.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/post-tool-use.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/stop.sh" }
        ]
      }
    ]
  },
  "env": {
    "NODE_ENV": "development"
  }
}
